# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными секретами в git.

# Токен бота от @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# Username бота без @ (нужен для возврата пользователя после оплаты)
BOT_USERNAME=my_p2p_bot

# Telegram ID администраторов через запятую (узнать свой id можно у @userinfobot)
ADMIN_IDS=123456789

# Публичный HTTPS-адрес, где будет открываться Mini App (тот же сервер, что и backend)
WEBAPP_URL=https://your-domain.example.com

# БД. Абсолютный путь важен, чтобы backend и bot видели один и тот же файл через общий volume ./data
DATABASE_URL=sqlite:////app/data/app.db

# ЮKassa (https://yookassa.ru/my/merchant/integration/api-keys)
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Параметры подписки
SUBSCRIPTION_PRICE_RUB=990
SUBSCRIPTION_DAYS=30

# Случайная строка для внутренних нужд (сгенерируйте, например: openssl rand -hex 32)
APP_SECRET=change_me_to_a_random_string
